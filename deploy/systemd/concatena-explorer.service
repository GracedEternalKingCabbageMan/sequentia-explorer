[Unit]
Description=Concatena explorer — static site + API proxy (serve-public, :8080)
After=concatena-electrs-seq.service concatena-electrs-t4.service
Wants=concatena-electrs-seq.service concatena-electrs-t4.service

[Service]
Type=simple
WorkingDirectory=/home/aejkohl/SequentiaByClaude/explorer
Environment=PORT=8080
Environment=NODE_PATH=/home/aejkohl/SequentiaByClaude/explorer/esplora/node_modules
Environment=SEQ_ELECTRS=127.0.0.1:3003
Environment=T4_ELECTRS=127.0.0.1:3004
ExecStart=/home/aejkohl/.local/bin/node /home/aejkohl/SequentiaByClaude/explorer/serve-public.js
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
